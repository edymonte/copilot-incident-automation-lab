# Environment variables — copy this file to .env and fill in the values
# NEVER commit .env to version control

# ServiceNow (Phase 2 & 4)
SNOW_INSTANCE=dev12345.service-now.com
SNOW_USER=admin
SNOW_PASSWORD=your-password-here

# Microsoft Teams (Phase 2)
TEAMS_WEBHOOK_URL=https://yourorg.webhook.office.com/webhookb2/...

# Jira (Phase 4)
JIRA_HOST=yourorg.atlassian.net
JIRA_USER=your-email@org.com
JIRA_TOKEN=your-jira-api-token

# GitHub (Phase 5 — simulate-incident.js)
# Use a PAT with repo scope
GITHUB_TOKEN=ghp_your-token-here
GITHUB_REPO=edymonte/copilot-incident-automation-lab
